; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Bascule.Godot"
config/description="Train game AI inside Godot in pure C# via Tensotron — no Python, no native runtime."
run/main_scene="res://examples/cartpole/CartPoleDemo.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")

[dotnet]

project/assembly_name="Bascule.Godot"

[editor_plugins]

enabled=PackedStringArray("res://addons/bascule/plugin.cfg")
